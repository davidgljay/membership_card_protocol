# Test-only config for press running under `wrangler dev` in the
# integration stack. All key material below is dummy/deterministic — never
# used for anything but local integration testing. wrangler's `.dev.vars`
# convention (must sit alongside wrangler.toml at container-run time —
# see env/press/Dockerfile) is how these reach the Worker's `process.env`
# shim under nodejs_compat. PRESS_KV itself (the KV binding) is declared in
# press/wrangler.toml and emulated locally by wrangler dev/miniflare — no
# separate service or env var needed for it.

PRESS_CARD_CID=bafybeidummytestcardcid0000000000000000000000000
PRESS_POLICY_CIDS=bafybeidummytestpolicycid00000000000000000000000
PRESS_MLDSA44_PRIVATE_
PRESS_SECP256R1_PRIVATE_KEY=0x52be2d89302e5e9b84160998303d25dc6b5957c8c9d189d8548e51313626f44d
PRESS_GAS_WALLET_PRIVATE_KEY=0x913f831c9b45f0091e496fb7d9a20df861c7983b60b314b3e1ad0440fbaaac47
PRESS_OHTTP_PRIVATE_KEY=Iicr3w-aJlwO_xRdJJGyBlBW1xBPbCQBfpUTaFbvPSU
# ARBITRUM_RPC_URL/REGISTRY_CONTRACT_ADDRESS/STORAGE_CONTRACT_ADDRESS are
# overridden at container startup by entrypoint.sh, which reads the local
# nitro-devnode deployment's freshly-generated contract addresses
# (deploy-contracts resets all chain state and redeploys fresh on every
# stack restart) — these values are unused placeholders kept only so
# config.ts's requireEnv() has something to load if entrypoint.sh's
# override is ever skipped.
ARBITRUM_RPC_URL=http://nitro-devnode:8547
EXPECTED_CHAIN_ID=412346
REGISTRY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
STORAGE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
IPFS_PROVIDER=kubo
KUBO_API_URL=http://ipfs:5001
KUBO_GATEWAY_URL=http://ipfs:8080
PORT=3000
LOG_LEVEL=debug
