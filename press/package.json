    "viem": "^2.30.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  }
}
