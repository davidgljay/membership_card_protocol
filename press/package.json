{
  "name": "@membership-card-protocol/press",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Card Protocol press — validates, co-signs, publishes, and registers cards",
  "scripts": {
    "dev": "nitro dev",
    "build": "nitro build",
    "build:lambda": "NITRO_PRESET=aws-lambda nitro build",
    "build:node": "NITRO_PRESET=node-server nitro build",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "//": "TODO: replace file: reference with versioned npm ref once @membership-card-protocol/verifier is published",
  "dependencies": {
