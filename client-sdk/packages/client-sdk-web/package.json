{
  "name": "@membership-card-protocol/client-sdk-web",
  "version": "0.0.1",
  "type": "module",
  "description": "Default web provider implementations (StorageProvider, SecureKeyProvider, PasskeyProvider, RealtimeTransportProvider, MultiInstanceLock) for @membership-card-protocol/client-sdk",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@matrix-org/matrix-sdk-crypto-wasm": "^18.3.1",
    "@membership-card-protocol/client-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
