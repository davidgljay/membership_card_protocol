    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@membership-card-protocol/client-sdk": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.3.0",
    "react-native": "^0.75.0",
    "typescript": "^5.8.3"
  }
}
