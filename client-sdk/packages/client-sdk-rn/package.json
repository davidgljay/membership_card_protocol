{
  "name": "@membership-card-protocol/client-sdk-rn",
  "version": "0.0.1",
  "type": "module",
  "description": "Default React Native provider implementations (StorageProvider, SecureKeyProvider, PasskeyProvider, RealtimeTransportProvider, MultiInstanceLock) for @membership-card-protocol/client-sdk",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
