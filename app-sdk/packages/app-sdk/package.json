{
  "name": "@membership-card-protocol/app-sdk",
  "version": "0.0.1",
  "type": "module",
  "description": "App SDK for the Card Protocol — app-side, key-independent holder functionality: offer construction, sub-card requests, messaging and private relay, shared across web and React Native",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-global-webcrypto vitest run",
    "test:watch": "NODE_OPTIONS=--experimental-global-webcrypto vitest"
  },
  "//": "TODO: replace file: references with versioned npm refs once @membership-card-protocol/verifier(-ipfs-provider) is published",
  "dependencies": {
    "@membership-card-protocol/verifier": "file:../../../membership_card_verifier/packages/verifier",
    "@membership-card-protocol/verifier-ipfs-provider": "file:../../../membership_card_verifier/packages/verifier-ipfs-provider",
    "@noble/ciphers": "^1.0.0",
    "@noble/hashes": "^1.7.2",
    "@noble/post-quantum": "^0.5.4",
    "hpke-js": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
