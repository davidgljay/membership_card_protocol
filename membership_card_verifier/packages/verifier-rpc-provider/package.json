{
  "name": "@membership-card-protocol/verifier-rpc-provider",
  "version": "0.1.0",
  "type": "module",
  "description": "ethers.js v6 RpcProvider implementation for @membership-card-protocol/verifier",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-global-webcrypto vitest run"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@membership-card-protocol/verifier": "workspace:*",
    "@types/node": "^26.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
