# DNS Governance Scripts — Environment Variables
# Copy to .env and fill in values before running any script.
# NEVER commit .env to version control.

# ===========================================================================
# Script signing key (DnsGovernanceBody, 1-of-1 for automated operations)
# ===========================================================================

# secp256r1 private key (32 bytes, hex, with or without 0x prefix).
# This key's pubkey must be registered in the DnsGovernanceBody keyset on-chain.
# Used ONLY for signing governance payloads — never for paying gas.
DNS_SCRIPT_PRIVATE_KEY=0x<32-byte hex>

# On-chain bytes32 address of the script key: keccak256(secp256r1_pubkey x||y).
# Derive with: node -e "
#   const {p256}=require('@noble/curves/nist.js');
#   const {keccak_256}=require('@noble/hashes/sha3.js');
#   const k=Buffer.from('<key_hex>','hex');
#   const pub=p256.getPublicKey(k,false).slice(1);
#   console.log('0x'+Buffer.from(keccak_256(pub)).toString('hex'));"
DNS_SCRIPT_ADDRESS=0x<64-hex-chars>

# Separate Ethereum wallet that holds ETH and pays gas for governance transactions.
# msg.sender on all governance transactions. Does not sign payloads.
DNS_SCRIPT_GAS_WALLET_KEY=0x<32-byte hex>

# ===========================================================================
# Press (card issuance and revocation)
# ===========================================================================

# Base URL of the authorized press that issues domain admin cards and submits
# 9xx revocations on behalf of the governance authority.
# The press holds its own signing keys and Filebase credentials.
# Governance scripts POST to: ${PRESS_URL}/dns/admin-card and ${PRESS_URL}/dns/revoke
PRESS_URL=https://press.example.com

# ===========================================================================
# Chain
# ===========================================================================

# Arbitrum One RPC endpoint.
RPC_URL=https://arb1.arbitrum.io/rpc

# Storage contract address (the stable protocol identifier — never changes).
REGISTRY_ADDRESS=0x<40-hex-chars>

# Logic contract address (for event subscriptions and write calls).
# Update when a logic upgrade is confirmed (listen for LogicUpgradeConfirmed event).
LOGIC_CONTRACT_ADDRESS=0x<40-hex-chars>

# DnsGovernancePolicyAddress — the policy under which domain admin cards are issued.
DNS_GOV_POLICY_ADDRESS=0x<64-hex-chars>

# The governance authority's own card address.
# Listed in the `auditors` field of all domain admin cards issued by this authority.
AUTHORITY_CARD_ADDRESS=0x<64-hex-chars>

# ===========================================================================
# IPFS (reads only — writes go through the press)
# ===========================================================================

# Public IPFS gateway for reading card documents and sub-card documents.
# Default: Filebase's public gateway. Any public IPFS gateway works.
IPFS_GATEWAY_URL=https://ipfs.filebase.io

# ===========================================================================
# Script C (policy-address-verifier) only
# ===========================================================================

# URL of the versioned brand name list JSON.
# Format: { "version": "1.0.0", "entries": [{ "name": "...", "canonicalDomains": ["..."] }] }
BRAND_NAME_LIST_URL=https://governance.example.com/brand-names.json

# File path for the last-processed block number cursor.
EVENT_CURSOR_STORE=/var/lib/dns-gov/policy-verifier-cursor.json

# SLA in hours: maximum time between a PolicyAddressSet event and its verification.
SLA_HOURS=24

# ===========================================================================
# Key management notes
# ===========================================================================
#
# DNS_SCRIPT_PRIVATE_KEY:
#   - Store in a hardware security module or secrets manager.
#   - Rotate by calling RotateGovernanceKeys(DnsGovernanceBody, newKeyset) with
#     board quorum, then update this value and DNS_SCRIPT_ADDRESS.
#
# DNS_SCRIPT_GAS_WALLET_KEY:
#   - Fund with enough ETH for expected governance transaction volume.
#   - Arbitrum One gas costs ~$0.01–0.10 per tx; $100 covers ~1000–10000 txs.
