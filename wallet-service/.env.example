# Postgres connection string (local dev: docker compose up, port 5433)
DATABASE_URL=postgres://wallet_service:wallet_service@localhost:5433/wallet_service

# --- Secrets backend (strategic-plan.md §Secret Storage) ---
# 'webcrypto' (default) — master key is a platform secret, wrapped/unwrapped
# via the runtime's native Web Crypto API. No AWS dependency.
# 'kms' (opt-in) — wraps/unwraps via AWS KMS Encrypt/Decrypt for a separate,
# IAM-gated, CloudTrail-audited credential domain.
SECRETS_BACKEND=webcrypto

# Required when SECRETS_BACKEND=webcrypto: base64url-encoded 32-byte AES key.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
WEBCRYPTO_MASTER_KEY=

# Required when SECRETS_BACKEND=kms: the KMS key ARN/id, and the AWS region.
# KMS_KEY_ID=
# AWS_REGION=

# --- Auth (implementation-plan.md §Step 1.4, §Step 2.1/2.2) ---
# HMAC secret signing/verifying session tokens.
SESSION_TOKEN_SECRET=

# WebAuthn relying party id and expected origin, used to verify passkey login
# assertions for existing-wallet open-offer acceptance (Step 2.1).
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

PORT=3000
LOG_LEVEL=info

# KV backend: 'cloudflare-kv' (requires a real Workers KV binding — see
# wrangler.toml's WALLET_KV — production Cloudflare deploys only) or
# 'postgres' (default; used for local dev, CI, and node-server/aws-lambda).
KV_BACKEND=postgres

# --- Notification providers (implementation-plan.md §Step 3.3) ---
# All optional. If unset, email/SMS fall back to a console-logging
# provider — fine for local dev, not for production (the 72-hour
# cancellation window's safety property depends on real delivery).
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# --- Federation (implementation-plan.md §Step 4.0/4.1) ---
# This instance's own wallet service identity — the mutable pointer of its
# wallet service card, and the ML-DSA-44 secret key that signs
# CardBindingAnnouncements and federation messages as the 'wallet_service'
# role. Generate a keypair with @noble/post-quantum's ml_dsa44.keygen();
# WALLET_SERVICE_ID = '0x' + keccak256(public_key) hex.
WALLET_SERVICE_ID=
WALLET_SERVICE_ENDPOINT=http://localhost:3000
WALLET_SERVICE_PRIVATE_KEY=

# Static peer list (message_routing.md §Wallet Service Registry §Peer List).
# JSON array of { wallet_service_id, endpoint, pubkey_hash }. Empty by
# default — single-instance deployment per OQ-WS-5; federation is opt-in.
PEER_LIST=[]

# Base URL for the relay's POST /deliver/{uuid} endpoint (Step 4.4).
RELAY_BASE_URL=http://localhost:4000

# --- Admin (strategic-plan.md §Goal 5: operational transparency) ---
# Bearer token gating /admin/* endpoints (routing table is at GET /bindings,
# unauthenticated by design — peers need it for startup sync). Operator-only;
# never share with end users or federation peers.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=

# --- On-chain subcard resolution (notification_relay.md v0.9 §Process 1
# steps 6-8, §Multi-Device Support "Deregistration") ---
# Arbitrum One RPC endpoint, read-only: resolves subcard_hash -> SubCardEntry
# (sub_card_doc_cid) to verify signed UUID-registration and
# deregistration envelopes (POST/DELETE .../subcards/{subcard_hash}[/uuids]).
# Same registry contract press/ writes to; wallet-service never submits
# transactions, so no private key is needed here.
ARBITRUM_RPC_URL=
REGISTRY_CONTRACT_ADDRESS=

# IPFS gateway used to fetch SubCardDocument by sub_card_doc_cid. Defaults to
# the same Filebase gateway press/ pins documents to.
IPFS_GATEWAY_URL=https://ipfs.filebase.io

# --- Matrix server (matrix-implementation-plan.md §Phase 2) ---
# The homeserver's own domain name, used in shadow-account derivation and
# join-attestation verification. Example: matrix.internal (dev), matrix.example.com (prod).
MATRIX_SERVER_NAME=matrix.internal

# WebSocket-capable (or push-capable) Arbitrum RPC endpoint for the watcher daemon's
# CardHeadUpdated subscription. May point to a different provider than ARBITRUM_RPC_URL
# if HTTP and WS endpoints are split, but must observe the same network/contract.
# Note: the subscription filter exposes the server's full membership graph to whichever
# provider serves this endpoint — see matrix_join_attestation_and_revocation.md §3.2
# for architectural notes on self-hosted vs. third-party RPC.
ARBITRUM_RPC_WS_URL=

# Join-attestation freshness window (seconds). Attestations older than this value
# are rejected as stale. Default: 300 (5 minutes).
JOIN_ATTESTATION_FRESHNESS_SECONDS=300

# Watcher backstop re-walk interval (seconds). Independent of event subscription,
# the watcher re-walks every address in its watch-set at this interval as a
# correctness floor to catch any missed or malformed events. Default: 3600 (1 hour).
WATCHER_BACKSTOP_INTERVAL_SECONDS=3600

# Filesystem path to the encrypted, persistent membership registry.
# This file stores (room_id, matrix_user_id) -> card_hash mappings for post-time
# identity resolution, as well as watch-set bookkeeping for the revocation watcher.
# Must be on a volume distinct from Synapse's own Postgres. Encrypted at rest
# using a key obtained via the same secrets abstraction as other Matrix credentials.
# Default: /data/membership_registry (mounted into the synapse container).
MATRIX_MEMBERSHIP_REGISTRY_PATH=/data/membership_registry

# Base64url-encoded AES-256 encryption key for the membership registry.
# Generated by scripts/generate-matrix-secrets.ts and mounted into the synapse container.
MATRIX_MEMBERSHIP_REGISTRY_KEY_PATH=/data/secrets/membership-registry.key
