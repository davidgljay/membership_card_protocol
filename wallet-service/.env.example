# Postgres connection string (local dev: docker compose up, port 5433)
DATABASE_URL=postgres://wallet_service:wallet_service@localhost:5433/wallet_service

# --- Secrets backend (strategic-plan.md §Secret Storage) ---
# 'webcrypto' (default) — master key is a platform secret, wrapped/unwrapped
# via the runtime's native Web Crypto API. No AWS dependency.
# 'kms' (opt-in) — wraps/unwraps via AWS KMS Encrypt/Decrypt for a separate,
# IAM-gated, CloudTrail-audited credential domain.
SECRETS_BACKEND=webcrypto

# Required when SECRETS_BACKEND=webcrypto: base64url-encoded 32-byte AES key.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
WEBCRYPTO_MASTER_KEY=

# Required when SECRETS_BACKEND=kms: the KMS key ARN/id, and the AWS region.
# KMS_KEY_ID=
# AWS_REGION=

# --- Auth (implementation-plan.md §Step 1.4, §Step 2.1/2.2) ---
# HMAC secret signing/verifying session tokens.
SESSION_TOKEN_SECRET=

# WebAuthn relying party id and expected origin, used to verify passkey login
# assertions for existing-wallet open-offer acceptance (Step 2.1).
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

PORT=3000
LOG_LEVEL=info

# KV backend: 'cloudflare-kv' (requires a real Workers KV binding — see
# wrangler.toml's WALLET_KV — production Cloudflare deploys only) or
# 'postgres' (default; used for local dev, CI, and node-server/aws-lambda).
KV_BACKEND=postgres
